  {
    "id": "5a7d50feb8d14ad9",
    "type": "http request",
    "z": "887060be91704551",
    "name": "🌐 GAS: Scrape Counties",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbwe-uOTzOWhqFvXn0O3t2B0V5Xo41W1n1-P13kHqH5TItn33rB6A9C5kQ17t5gA6C9t/exec?action=scrapeExpansionCounties",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 600,

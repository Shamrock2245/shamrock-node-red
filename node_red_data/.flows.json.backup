    "func": "msg.headers = {\n    \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\"),\n    \"Content-Type\": \"application/json; charset=utf-8\"\n};\nmsg.payload = {\n    \"channel\": \"#alerts\",\n    \"text\": `🌤️ *Weather-Based Posting*\\n\\n${msg.weatherContext || 'Boost triggered'}\\n\\n_Extra posts scheduled by Node-RED_`\n};\nreturn msg;",

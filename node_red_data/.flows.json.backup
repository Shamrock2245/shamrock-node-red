  {
    "id": "11labs-status-process",
    "type": "function",
    "z": "tab-advanced",
    "name": "Process Voice Call Status",
    "func": "// Process ElevenLabs voice call status updates / conversation events\nconst event = msg.payload;\nconst eventType = event.type || event.event || 'unknown';\nconst callId = event.conversation_id || event.call_id || 'N/A';\n\nmsg.callEvent = {\n    type: eventType,\n    callId: callId,\n    status: event.status || event.state || 'unknown',\n    duration: event.duration || null,\n    transcript: event.transcript || event.messages || null,\n    timestamp: new Date().toISOString()\n};\n\n// Format Slack notification for important events\nconst importantEvents = ['call.ended', 'conversation.ended', 'call_ended', 'ended'];\nif (importantEvents.includes(eventType) || event.status === 'completed') {\n    msg.slackAlert = {\n        channel: '#alerts',\n        text: `📞 *Voice Call Update*\\n> Call ID: ${callId}\\n> Status: ${msg.callEvent.status}\\n> Duration: ${msg.callEvent.duration || 'N/A'}s`\n    };\n}\n\n// Forward full payload to GAS for logging\nmsg.payload = {\n    action: 'logVoiceCallEvent',\n    ...msg.callEvent\n};\n\nmsg.headers = {\n    'Content-Type': 'application/json'\n};\n\nnode.status({fill: eventType.includes('end') ? \"red\" : \"green\", shape:\"dot\", text: eventType + \" | \" + callId.substring(0,8)});\nreturn msg;",
    "outputs": 1,
    "x": 430,
    "y": 760,
    "wires": [
      [
        "11labs-gas-log",
        "11labs-slack-alert",
        "11labs-status-debug"
      ]
    ]
  },

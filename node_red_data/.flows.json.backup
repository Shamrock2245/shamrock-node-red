    "func": "// Process Telegram MiniApp (WebApp) data submissions\nconst data = msg.payload;\n\nmsg.miniAppData = {\n    type: data.type || 'form_submit',\n    userId: data.user_id || data.userId,\n    chatId: data.chat_id || data.chatId,\n    formData: data.form_data || data.formData || data.data || {},\n    source: 'telegram_miniapp',\n    timestamp: new Date().toISOString()\n};\n\n// Forward to GAS for processing (intake form, location check-in, etc.)\nmsg.payload = {\n    action: 'processMiniAppSubmission',\n    ...msg.miniAppData\n};\n\nmsg.headers = {\n    'Content-Type': 'application/json'\n};\n\nnode.status({fill:\"purple\",shape:\"dot\",text: msg.miniAppData.type + \" from user \" + (msg.miniAppData.userId || \"?\")});\nreturn msg;",

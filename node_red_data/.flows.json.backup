  {
    "id": "scraper-push-process",
    "type": "function",
    "z": "tab-advanced",
    "name": "Process Scraper Results",
    "func": "// Process incoming scraper results and route to dashboard + bounty filter\nconst data = msg.payload;\nconst county = data.county || 'Unknown';\nconst records = Array.isArray(data.records) ? data.records : \n                Array.isArray(data.arrests) ? data.arrests :\n                Array.isArray(data) ? data : [];\n\nif (records.length === 0) {\n    node.status({fill:\"yellow\",shape:\"ring\",text:\"No records from \" + county});\n    return null;\n}\n\nnode.status({fill:\"green\",shape:\"dot\",text:records.length + \" records from \" + county});\n\n// msg 1: Forward to Shamrock's Leads / Bounty Board filter\n// msg 2: Forward to Scout bounty filter  \n// msg 3: Log to GAS\nlet msg1 = {payload: records};\nlet msg2 = {payload: {arrests: records, county: county}};\nlet msg3 = {\n    payload: {\n        action: 'logScraperResults',\n        county: county,\n        count: records.length,\n        timestamp: new Date().toISOString()\n    },\n    headers: {'Content-Type': 'application/json'}\n};\n\nreturn [msg1, msg2, msg3];",
    "outputs": 3,
    "x": 430,
    "y": 960,
    "wires": [
      [],
      [
        "scout_filter_bounty"
      ],
      [
        "scraper-log-gas"
      ]
    ]
  },

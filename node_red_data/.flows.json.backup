    "func": "// Prepare request for court email processing\nmsg.payload = { action: 'processCourtEmails' };\nmsg.headers = { 'Content-Type': 'application/json' };\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Scanning inbox...\"});\nreturn msg;",

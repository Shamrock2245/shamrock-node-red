  {
    "id": "fn_poll_wo",
    "type": "function",
    "z": "tab-shamrock",
    "name": "Check Scraper API",
    "func": "let watchList = global.get('walkout_watch_list') || {};\nlet msgs = [];\nfor (let bookingNum in watchList) {\n    if (watchList[bookingNum].status === 'WATCHING') {\n        // In a real prod setup, this triggers the HTTP node to our Lee County Scraper Endpoint.\n        // If scraper returns {\"status\": \"RELEASED\"}, we route to Twilio SMS and flip status to 'RELEASED_NOTIFIED'.\n        msgs.push({ \n            payload: { bookingNum: bookingNum, phone: watchList[bookingNum].phone, action: 'check_status' } \n        });\n    }\n}\nreturn [msgs];",
    "outputs": 1,
    "x": 450,
    "y": 1460,
    "wires": [
      []
    ]
  },

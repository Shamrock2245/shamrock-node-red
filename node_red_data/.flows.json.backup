    "y": 80,
    "wires": []
  },
  {
    "id": "node-debug-payload",
    "type": "debug",
    "z": "tab-shamrock",
    "name": "Debug Wix Payload",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": false,
    "complete": "payload",
    "targetType": "msg",
    "statusVal": "",
    "statusType": "auto",

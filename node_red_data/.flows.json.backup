  {
    "id": "ngrok-config-setter",
    "type": "function",
    "z": "tab-advanced",
    "name": "Configure Global Vars",
    "func": "// Set critical global context variables\nglobal.set('NGROK_BASE_URL', 'https://pseudospherical-etta-untactually.ngrok-free.dev');\nglobal.set('GAS_URL', 'https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec');\nglobal.set('GAS_URL_ALT', 'https://script.google.com/macros/s/AKfycbyCIDPzA_EA1B1SGsfhYiXRGKM8z61EgACZdDPILT_MjjXee0wSDEI0RRYthE0CvP-Z/exec');\nglobal.set('GAS_URL_OPS', 'https://script.google.com/macros/s/AKfycbwe-uOTzOWhqFvXn0O3t2B0V5Xo41W1n1-P13kHqH5TItn33rB6A9C5kQ17t5gA6C9t/exec');\n\nconst endpoints = {\n    'Wix Intake':        'https://pseudospherical-etta-untactually.ngrok-free.dev/wix-intake',\n    'Wix Intake Start':  'https://pseudospherical-etta-untactually.ngrok-free.dev/intake-start',\n    'Wix Intake Complete': 'https://pseudospherical-etta-untactually.ngrok-free.dev/intake-complete',\n    'Scraper Update':    'https://pseudospherical-etta-untactually.ngrok-free.dev/api/scraper/webhook',\n    'Scraper Results':   'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/scraper-results',\n    'WhatsApp (Twilio)': 'https://pseudospherical-etta-untactually.ngrok-free.dev/whatsapp',\n    'Telegram (legacy)': 'https://pseudospherical-etta-untactually.ngrok-free.dev/telegram',\n    'Telegram Bot':      'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/telegram-bot',\n    'Telegram Convo':    'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/telegram-conversation',\n    'Telegram MiniApp':  'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/telegram-miniapp',\n    'ElevenLabs Status': 'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/elevenlabs-status',\n    'SignNow Events':    'https://pseudospherical-etta-untactually.ngrok-free.dev/signnow-event',\n    'Scout/Arrest':      'https://pseudospherical-etta-untactually.ngrok-free.dev/webhook/scout'\n};\n\nglobal.set('WEBHOOK_ENDPOINTS', endpoints);\nnode.status({fill:\"green\",shape:\"dot\",text:\"Configured \" + Object.keys(endpoints).length + \" endpoints\"});\n\n// Log to console\nnode.warn(\"=== WEBHOOK ENDPOINTS CONFIGURED ===\");\nfor (let [name, url] of Object.entries(endpoints)) {\n    node.warn(name + \": \" + url);\n}\n\nreturn msg;",
    "outputs": 1,
    "x": 400,
    "y": 1060,
    "wires": [
      [
        "ngrok-config-debug"
      ]
    ]

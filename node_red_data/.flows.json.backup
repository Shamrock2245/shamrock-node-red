  {
    "id": "e1ffe2c13c804c2e",
    "type": "comment",
    "z": "e6949e9df6bc4905",
    "name": "📱 WHATSAPP DRIP CAMPAIGN",
    "info": "⚠️ THIS TAB IS DISABLED until 10DLC/A2P approval.\nEnable from Node-RED → double-click tab → uncheck Disabled.\n\nMirrors The Closer but via WhatsApp (98% open rates).\nDrip tiers: 1h, 24h, 72h after abandonment.",
    "x": 300,
    "y": 40,
    "wires": []
  },
  {
    "id": "ab402003ae6b412f",
    "type": "inject",
    "z": "e6949e9df6bc4905",
    "name": "⏰ Every 30 Min",
    "props": [
      {
        "p": "payload"
      },
      {
        "p": "topic",
        "vt": "str"
      }
    ],
    "repeat": "",
    "crontab": "*/30 * * * *",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 140,
    "y": 160,
    "wires": [
      [
        "44bfbdc925b146ab"
      ]
    ]
  },
  {
    "id": "44bfbdc925b146ab",
    "type": "function",
    "z": "e6949e9df6bc4905",
    "name": "📨 Fetch Abandoned",
    "func": "// Fetch abandoned intakes from GAS\nmsg.payload = { action: 'getAbandonedIntakes' };\nmsg.headers = { 'Content-Type': 'application/json' };\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Fetching abandoned intakes...\"});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 340,
    "y": 160,
    "wires": [
      [
        "2f40ac0ecefd44ee"
      ]
    ]
  },
  {
    "id": "2f40ac0ecefd44ee",
    "type": "http request",
    "z": "e6949e9df6bc4905",
    "name": "🌐 GAS: Get Leads",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec?action=getAbandonedIntakes",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 540,
    "y": 160,
    "wires": [
      [
        "a666b20f177d48dd"
      ]
    ]
  },
  {
    "id": "a666b20f177d48dd",
    "type": "function",
    "z": "e6949e9df6bc4905",
    "name": "🔍 Filter Eligible",
    "func": "// Filter leads eligible for WhatsApp (have phone, not yet WA-contacted)\nconst result = msg.payload || {};\nconst leads = Array.isArray(result.leads) ? result.leads : [];\n\nconst eligible = leads.filter(l => {\n    const phone = l.phone || l.phoneNumber || '';\n    const waContacted = l.whatsappContacted || false;\n    return phone.length >= 10 && !waContacted;\n});\n\nif (eligible.length === 0) {\n    node.status({fill:\"grey\", shape:\"ring\", text:\"No eligible leads\"});\n    return null;\n}\n\nmsg.eligibleLeads = eligible;\nnode.status({fill:\"yellow\", shape:\"dot\", text: eligible.length + \" leads to reach\"});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 740,
    "y": 160,
    "wires": [
      [
        "ab02778a0b954500"
      ]
    ]
  },
  {
    "id": "ab02778a0b954500",
    "type": "function",
    "z": "e6949e9df6bc4905",
    "name": "📝 Build WA Messages",
    "func": "// Build WhatsApp messages for each lead\n// Uses Twilio WhatsApp Sandbox format\nconst leads = msg.eligibleLeads || [];\nconst messages = leads.map(lead => {\n    const name = lead.name || lead.firstName || 'there';\n    const phone = (lead.phone || lead.phoneNumber || '').replace(/\\D/g, '');\n    \n    // Determine drip tier based on time since abandonment\n    const hoursAgo = lead.hoursAbandoned || 1;\n    let template;\n    \n    if (hoursAgo <= 2) {\n        template = `Hi ${name}, this is Shamrock Bail Bonds. We noticed you started an application — we're here to help 24/7. Reply YES to continue or call (239) 955-0178. 🍀`;\n    } else if (hoursAgo <= 24) {\n        template = `${name}, just checking in from Shamrock Bail Bonds. We know this is stressful — our team is standing by to help your loved one come home. Call/text anytime: (239) 955-0178 🍀`;\n    } else {\n        template = `Hi ${name}, Shamrock Bail Bonds here. We're still available to help with your bail application. Fast, confidential service. Call us 24/7: (239) 955-0178 🍀`;\n    }\n    \n    return {\n        to: 'whatsapp:+1' + phone,\n        from: 'whatsapp:+1' + (global.get('TWILIO_WA_NUMBER') || ''),\n        body: template,\n        leadId: lead.id || lead.caseId\n    };\n});\n\nmsg.waMessages = messages;\nmsg.payload = { \n    action: 'sendWhatsAppBatch',\n    messages: messages \n};\nmsg.headers = { 'Content-Type': 'application/json' };\nnode.status({fill:\"green\", shape:\"dot\", text: messages.length + \" messages queued\"});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 960,
    "y": 160,
    "wires": [
      [
        "5c04fc2f4c05479a"
      ]
    ]
  },
  {
    "id": "5c04fc2f4c05479a",
    "type": "http request",
    "z": "e6949e9df6bc4905",
    "name": "📤 GAS: Send Batch",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec?action=sendWhatsAppBatch",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 1180,
    "y": 160,
    "wires": [
      [
        "9239a2c3059f4255"
      ]
    ]
  },
  {
    "id": "9239a2c3059f4255",
    "type": "function",
    "z": "e6949e9df6bc4905",
    "name": "✅ Check Result",
    "func": "const result = msg.payload || {};\nconst sent = result.sent || 0;\nconst failed = result.failed || 0;\n\nmsg.waResult = { sent, failed };\nnode.status({fill: failed > 0 ? \"yellow\" : \"green\", shape:\"dot\", text: `✅ ${sent} sent, ❌ ${failed} failed`});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1380,
    "y": 160,
    "wires": [
      [
        "ab98e87d89e04660"
      ]
    ]
  },
  {
    "id": "ab98e87d89e04660",
    "type": "function",
    "z": "e6949e9df6bc4905",
    "name": "📢 Slack Report",
    "func": "msg.headers = {\n    \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\"),\n    \"Content-Type\": \"application/json; charset=utf-8\"\n};\nconst r = msg.waResult;\nmsg.payload = {\n    \"channel\": \"#alerts\",\n    \"text\": `📱 *WhatsApp Campaign Report*\\n\\n✅ Sent: ${r.sent}\\n❌ Failed: ${r.failed}\\n\\n_Via Twilio WhatsApp Business_`\n};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1560,

  {
    "id": "1ba0923346104ec4",
    "type": "function",
    "z": "92127b16db094acd",
    "name": "📊 Fetch Compliance",
    "func": "msg.payload = { action: 'getComplianceStatus' };\nmsg.headers = { 'Content-Type': 'application/json' };\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Checking compliance...\"});\nreturn msg;",

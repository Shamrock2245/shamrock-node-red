    "type": "http request",
    "z": "47df6624715c4999",
    "name": "🌐 GAS: SignNow",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec?action=createSignNowPacket",

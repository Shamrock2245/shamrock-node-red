    "type": "http request",
    "z": "62372935a6134827",
    "name": "📋 GAS: Daily Ops",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec?action=sendDailyOpsReport",

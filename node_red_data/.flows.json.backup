  {
    "id": "tg-convo-process",
    "type": "function",
    "z": "tab-advanced",
    "name": "Process Conversation",
    "func": "// Processes Telegram conversation updates\nconst update = msg.payload;\nconst message = update.message || update.channel_post || {};\n\nmsg.conversationData = {\n    chatId: message.chat?.id,\n    chatType: message.chat?.type || 'private',\n    text: message.text || '',\n    from: message.from?.first_name || 'Unknown',\n    timestamp: new Date().toISOString()\n};\n\n// Forward to GAS for AI processing\nmsg.payload = {\n    action: 'processConversation',\n    source: 'telegram',\n    ...msg.conversationData\n};\n\nmsg.headers = {\n    'Content-Type': 'application/json'\n};\n\nnode.status({fill:\"blue\",shape:\"dot\",text:msg.conversationData.chatType + \": \" + msg.conversationData.text.substring(0,30)});\nreturn msg;",
    "outputs": 1,
    "x": 420,
    "y": 660,
    "wires": [
      [
        "tg-convo-gas",
        "tg-convo-debug"
      ]
    ]
  },

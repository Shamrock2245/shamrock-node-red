  {
    "id": "87a0317c6e084bd6",
    "type": "comment",
    "z": "92127b16db094acd",
    "name": "🚨 NO-SHOW ESCALATION",
    "info": "Checks defendant compliance every hour.\nMissed check-in → Yellow alert (attempt contact).\nMissed court date → RED CRITICAL (immediate action).\nProtects the bottom line on active bonds.",
    "x": 300,

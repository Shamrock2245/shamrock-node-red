  {
    "id": "tg-bot-router",
    "type": "function",
    "z": "tab-advanced",
    "name": "Route Bot Update",
    "func": "// Routes Telegram updates by type\nconst update = msg.payload;\nconst msgType = update.message ? 'message' :\n                update.callback_query ? 'callback' :\n                update.inline_query ? 'inline' :\n                update.my_chat_member ? 'membership' : 'other';\n\nmsg.topic = msgType;\n\n// Extract key info\nif (update.message) {\n    msg.chatId = update.message.chat.id;\n    msg.text = update.message.text || '';\n    msg.from = update.message.from;\n} else if (update.callback_query) {\n    msg.chatId = update.callback_query.message.chat.id;\n    msg.callbackData = update.callback_query.data;\n    msg.from = update.callback_query.from;\n}\n\nnode.status({fill:\"green\",shape:\"dot\",text:msgType + \" from \" + (msg.from?.first_name || \"unknown\")});\nreturn msg;",
    "outputs": 1,
    "x": 400,
    "y": 560,
    "wires": [
      [
        "tg-bot-gas-forward",
        "tg-bot-debug"
      ]
    ]
  },

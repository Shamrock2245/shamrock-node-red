[
  {
    "id": "tab-shamrock",
    "type": "tab",
    "label": "Shamrock Automations",
    "disabled": false,
    "info": "This is the primary flow for receiving Wix webhooks and routing data to Twilio, Slack, or Google Apps Script."
  },
  {
    "id": "tab-advanced",
    "type": "tab",
    "label": "The Digital Workforce (Advanced)",
    "disabled": false,
    "info": "Shamrock Bail Bonds AI Workforce & Automations"
  },
  {
    "id": "075324f9f77c4bfe",
    "type": "tab",
    "label": "Social Auto-Pilot",
    "disabled": false,
    "info": "Automated social media posting — 3x daily via GAS SocialPublisher"
  },
  {
    "id": "349776f462c04333",
    "type": "tab",
    "label": "The Court Clerk",
    "disabled": false,
    "info": "Processes court emails every 30 min via GAS CourtEmailProcessor"
  },
  {
    "id": "3b50687c49b34aab",
    "type": "tab",
    "label": "The Closer",
    "disabled": false,
    "info": "Automated drip campaigns for abandoned intakes — SMS follow-up at 1h, 24h, 72h"
  },
  {
    "id": "62372935a6134827",
    "type": "tab",
    "label": "Morning Briefing",
    "disabled": false,
    "info": "Daily 7AM ops report + system health check to Telegram & Slack"
  },
  {
    "id": "da825df237884267",
    "type": "tab",
    "label": "The Bounty Hunter",
    "disabled": false,
    "info": "Scraper results → lead scoring → hot leads to Slack"
  },
  {
    "id": "9ade1856b4a143be",
    "type": "tab",
    "label": "Watchdog",
    "disabled": false,
    "info": "System health monitor — pings all services every 5 min, alerts on failures"
  },
  {
    "id": "47a279345d2c43f7",
    "type": "tab",
    "label": "GAS Scheduler",
    "disabled": false,
    "info": "CENTRALIZED SCHEDULER — Node-RED is the single control plane.\nAll GAS time-driven triggers have been migrated here.\nRun migrateTriggersToNodeRED() in GAS to remove old triggers."
  },
  {
    "id": "e6949e9df6bc4905",
    "type": "tab",
    "label": "WhatsApp Campaigns",
    "disabled": true,
    "info": "⚠️ DISABLED — Waiting on 10DLC/A2P campaign approval.\nEnable this tab once approved.\n\nMirrors The Closer's SMS drip with WhatsApp via Twilio.\n98% open rates vs 20% for SMS."
  },
  {
    "id": "6647cd5307914885",
    "type": "tab",
    "label": "SignNow Tracker",
    "disabled": false,
    "info": "Polls SignNow for unsigned packets and sends reminders.\nAuto-reminds at 2h, 12h, 24h after sending."
  },
  {
    "id": "2916c0669be64f55",
    "type": "tab",
    "label": "Review Harvester",
    "disabled": false,
    "info": "48h after bond posted → auto-text asking for Google review.\nBoosts SEO and Google Business Profile."
  },
  {
    "id": "3f0cdaee1ab64048",
    "type": "tab",
    "label": "Payment Reminders",
    "disabled": true,
    "info": "⚠️ DISABLED — Waiting on text campaign approval.\n3 days before payment plan installment → SMS reminder.\nReduces missed payments and forfeiture risk."
  },
  {
    "id": "92127b16db094acd",
    "type": "tab",
    "label": "No-Show Escalation",
    "disabled": false,
    "info": "Monitors check-ins and court appearances.\nMissed check-in or court date → instant Slack + staff call.\nProtects the bottom line on active bonds."
  },
  {
    "id": "47df6624715c4999",
    "type": "tab",
    "label": "Intake Pipeline",
    "disabled": false,
    "info": "End-to-end intake: Webhook → Slack → SignNow packet → Signing link → Confirmation.\nNo manual steps. Fully automated from intake to bond posting."
  },
  {
    "id": "c9cd99104acc4337",
    "type": "tab",
    "label": "Revenue Snapshot",
    "disabled": false,
    "info": "Daily at 6 PM — pulls payment data, calculates revenue stats, sends to Slack + Telegram."
  },
  {
    "id": "887060be91704551",
    "type": "tab",
    "label": "The Scout",
    "disabled": false,
    "info": "Geographic expansion — scrapes county jails for new arrest data.\nTargets counties beyond current coverage.\nFeeds into Bounty Hunter for lead scoring."
  },
  {
    "id": "50d6f3b3f3794f04",
    "type": "tab",
    "label": "Staff Performance",
    "disabled": false,
    "info": "Weekly staff performance report — response times, cases closed, revenue per agent."
  },
  {
    "id": "3733b542a5e24d06",
    "type": "tab",
    "label": "Weather Posting",
    "disabled": false,
    "info": "Adjusts social posting based on local weather and events.\nStorms + holidays = higher arrest rates = more posts."
  },

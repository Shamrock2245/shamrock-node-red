  {
    "id": "4f46bfeb4fac472a",
    "type": "function",
    "z": "tab-shamrock",
    "name": "Calculate Flight Risk",
    "func": "let score = 50;\nlet credit = parseInt(msg.payload.creditScore) || 500;\nlet years = parseInt(msg.payload.yearsEmployed) || 0;\nlet home = msg.payload.homeowner === true;\n\nif (credit > 700) score -= 20;\nelse if (credit < 550) score += 20;\n\nif (years > 5) score -= 15;\nelse if (years < 1) score += 10;\n\nif (home) score -= 15;\nelse score += 10;\n\nscore = Math.max(0, Math.min(100, score));\nmsg.payload = {\n    action: 'sendSlackAlert',\n    text: `📊 **Risk Analysis Complete**\\nFlight Risk Score: ${score}/100\\nCredit: ${credit}\\nEmployed: ${years} yrs\\nHomeowner: ${home}`,\n    channel: '#alerts'\n};\nreturn msg;",
    "outputs": 1,
    "x": 550,
    "y": 840,
    "wires": [
      [
        "fef84041e4f3456f"
      ]
    ]
  },
  {

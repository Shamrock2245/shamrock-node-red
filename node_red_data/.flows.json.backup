  {
    "id": "235fcb59ebfc4567",
    "type": "comment",
    "z": "3733b542a5e24d06",
    "name": "🌤️ WEATHER-BASED POSTING",
    "info": "6 AM daily — checks weather + events.\nStorms, holidays, weekends → extra social posts.\nUses free Open-Meteo API for Fort Myers weather.",
    "x": 300,
    "y": 40,
    "wires": []
  },
  {
    "id": "ec518cd7a5a748b2",
    "type": "inject",
    "z": "3733b542a5e24d06",
    "name": "⏰ 6:00 AM Daily",
    "props": [
      {
        "p": "payload"
      },
      {
        "p": "topic",
        "vt": "str"
      }
    ],
    "repeat": "",
    "crontab": "0 6 * * *",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 140,
    "y": 180,
    "wires": [
      [
        "2421af60335b43ec"
      ]
    ]
  },
  {
    "id": "2421af60335b43ec",
    "type": "function",
    "z": "3733b542a5e24d06",
    "name": "🌡️ Fetch Weather",
    "func": "// Fetch weather for Fort Myers area (Lee County)\nmsg.url = 'https://api.open-meteo.com/v1/forecast?latitude=26.6406&longitude=-81.8723&daily=weathercode,temperature_2m_max&timezone=America/New_York&forecast_days=1';\nmsg.method = 'GET';\nmsg.headers = {};\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Checking weather...\"});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 340,
    "y": 180,
    "wires": [
      [
        "0a61addd1b0247c9"
      ]
    ]
  },
  {
    "id": "0a61addd1b0247c9",
    "type": "http request",
    "z": "3733b542a5e24d06",
    "name": "🌐 Open-Meteo API",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 540,
    "y": 180,
    "wires": [
      [
        "0f472b5749244fda"
      ]
    ]
  },
  {
    "id": "0f472b5749244fda",
    "type": "function",
    "z": "3733b542a5e24d06",
    "name": "📊 Analyze & Decide",
    "func": "// Analyze weather and decide posting strategy\nconst weather = msg.payload || {};\nconst daily = weather.daily || {};\nconst weatherCode = (daily.weathercode || [0])[0];\nconst tempMax = (daily.temperature_2m_max || [85])[0];\n\n// Weather codes: 0-3 clear, 45-48 fog, 51-67 rain, 71-77 snow, 80-82 showers, 95-99 thunderstorm\nlet postBoost = false;\nlet weatherContext = '';\nlet extraPosts = 0;\n\nif (weatherCode >= 95) {\n    // Thunderstorms — historically correlated with more arrests\n    weatherContext = '⛈️ Severe weather alert! Historically, storm days see 20% more arrests.';\n    extraPosts = 2;\n    postBoost = true;\n} else if (weatherCode >= 80) {\n    weatherContext = '🌧️ Rainy day — indoor posting boost.';\n    extraPosts = 1;\n    postBoost = true;\n} else if (tempMax > 95) {\n    weatherContext = '🌡️ Extreme heat — stay safe, SWFL.';\n    extraPosts = 1;\n    postBoost = true;\n}\n\n// Check for holidays/events (simplified)\nconst today = new Date();\nconst month = today.getMonth() + 1;\nconst day = today.getDate();\nconst dayOfWeek = today.getDay();\n\n// Weekends + holidays = more arrests\nif (dayOfWeek === 0 || dayOfWeek === 6) {\n    weatherContext += '\\n📅 Weekend — higher arrest rates typical.';\n    extraPosts += 1;\n    postBoost = true;\n}\n\n// Major holidays\nif ((month === 7 && day === 4) || (month === 12 && (day >= 24 && day <= 31)) ||\n    (month === 1 && day === 1) || (month === 11 && day >= 22 && day <= 28)) {\n    weatherContext += '\\n🎉 Holiday period — significantly elevated arrest rates.';\n    extraPosts += 2;\n    postBoost = true;\n}\n\nif (!postBoost) {\n    node.status({fill:\"grey\", shape:\"ring\", text: \"Normal day (code:\" + weatherCode + \" \" + tempMax + \"°F)\"});\n    return null;\n}\n\nmsg.payload = {\n    action: 'publishSocial',\n    content: `🍀 Shamrock Bail Bonds is here 24/7. ${weatherContext.split('\\n')[0]} If you or a loved one needs help, call (239) 955-0178. Fast, confidential service across SWFL. shamrockbailbonds.biz`,\n    platforms: ['twitter', 'facebook', 'telegram'],\n    postType: 'weather-boost',\n    extraPosts: extraPosts\n};\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.weatherContext = weatherContext;\nnode.status({fill:\"yellow\", shape:\"dot\", text: `${extraPosts} extra post(s) triggered`});\nreturn msg;",

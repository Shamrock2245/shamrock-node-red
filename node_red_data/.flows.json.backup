  {
    "id": "07507efca8d84f32",
    "type": "ui-template",
    "z": "tab-shamrock",
    "group": "1c0be978acad40dc",
    "name": "Shamrock's Leads",
    "order": 5,
    "width": 6,
    "height": 4,
    "format": "<template>\n  <div style=\"padding:12px; height:100%; overflow-y:auto; background:#1e1e1e; border-radius:8px;\">\n    <h3 style=\"color:#d4af37; margin:0 0 12px; font-weight:bold; border-bottom:1px solid #333; padding-bottom:8px;\">☘️ SHAMROCK'S LEADS</h3>\n    <div v-if=\"msg?.payload && msg.payload.length > 0\">\n      <div v-for=\"(item, i) in msg.payload\" :key=\"i\" style=\"padding:10px; margin-bottom:8px; background:#2a2a2a; border-left:4px solid; border-radius:4px;\" :style=\"{'border-left-color': item.isReturning ? '#10b981' : '#ef4444'}\">\n        <strong style=\"color:#fff; font-size:1.1em;\">{{item.name}}</strong>\n        <span v-if=\"item.isReturning\" style=\"margin-left:8px; background:#10b981; color:#fff; padding:2px 6px; border-radius:12px; font-size:0.75em; font-weight:bold;\">RETURNING CLIENT</span>\n        <span style=\"float:right; color:#ef4444; font-weight:bold;\">${{item.bond.toLocaleString()}}</span>\n        <div style=\"color:#aaa; font-size:0.9em; margin-top:4px;\">{{item.county}} | {{item.charges}}</div>\n      </div>\n    </div>\n    <div v-else style=\"color:#888; text-align:center; padding:20px;\">Scanning for targets...</div>\n  </div>\n</template>",
    "storeOutMessages": true,
    "passthru": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 300,
    "y": 340,
    "wires": [
      []
    ]
  },
  {
    "id": "27f1f6ed9005447e",
    "type": "ui-template",
    "z": "tab-shamrock",
    "group": "58ad934f1fea45a5",
    "name": "Live Chat Feed",
    "order": 1,
    "width": 6,
    "height": 5,
    "format": "<div style='height:100%; overflow-y:scroll; padding:10px;' class='custom-inbox'>\n  <ul v-for=\"msg in msg.payload\" :key=\"msg.id\" style='list-style:none; padding:0;'>\n    <li style='margin-bottom:8px; display:flex; flex-direction:column;' :style='msg.isBot ? \"align-items:flex-start;\" : \"align-items:flex-end;\"'>\n      <div style='max-width:80%; padding:8px 12px; border-radius:12px;' :style='msg.isBot ? \"background:#333; color:#EEE;\" : \"background:#D4AF37; color:#121212;\"'>\n        <strong>{{msg.sender}}:</strong> {{msg.text}}\n      </div>\n    </li>\n  </ul>\n</div>",
    "storeOutMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 300,
    "y": 420,
    "wires": [
      []
    ]
  },

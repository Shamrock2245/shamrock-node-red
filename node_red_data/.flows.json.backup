    "id": "11labs-slack-alert",
    "type": "function",
    "z": "tab-advanced",
    "name": "Slack Voice Alert",
    "func": "if (!msg.slackAlert) return null;\nmsg.headers = {\n    \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\"),\n    \"Content-Type\": \"application/json; charset=utf-8\"\n};\nmsg.payload = msg.slackAlert;\nreturn msg;",
    "outputs": 1,

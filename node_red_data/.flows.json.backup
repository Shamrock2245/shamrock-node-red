    "paytoqs": "ignore",
    "url": "https://script.google.com/macros/s/AKfycbzZfPy0nFDWWKcn731yX8kg9A0t_sCFK3rOdVBddGK1/exec?action=telegramBotUpdate",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,

        "b9d12c3d7f284c4b"
      ]
    ]
  },
  {
    "id": "695e422211384551",
    "type": "function",
    "z": "6647cd5307914885",
    "name": "🟡 12h Moderate",
    "func": "// Moderate 12-hour reminder\nconst docs = msg.payload || [];\nmsg.payload = {\n    action: 'sendSigningReminder',\n    tier: 'moderate',\n    documents: docs.map(d => ({\n        documentId: d.documentId || d.id,\n        recipientName: d.recipientName || d.name,\n        recipientPhone: d.recipientPhone || d.phone,\n        recipientEmail: d.recipientEmail || d.email,\n        message: `${d.recipientName || 'Hi'}, your bail bond paperwork still needs your signature. Your loved one is waiting — please sign ASAP so we can get them home. Link in your email or call (239) 955-0178 🍀`\n    }))\n};\nmsg.headers = { 'Content-Type': 'application/json' };\nnode.status({fill:\"yellow\", shape:\"dot\", text: docs.length + \" moderate reminders\"});\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],

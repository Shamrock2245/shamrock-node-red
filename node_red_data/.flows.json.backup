    "wires": []
  },
  {
    "id": "d5d6364796504126",
    "type": "http in",
    "z": "47df6624715c4999",
    "name": "📥 /intake-pipeline",
    "url": "/intake-pipeline",
    "method": "post",
    "upload": false,
    "swaggerDoc": "",

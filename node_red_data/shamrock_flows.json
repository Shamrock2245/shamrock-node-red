{
  "id": "node-format-slack",
  "type": "function",
  "z": "tab-shamrock",
  "name": "Format Slack Block Kit message",
  "func": "const payload = msg.payload || {};\nconst name = payload.name || \"Unknown Client\";\nconst phone = payload.phone || \"No phone provided\";\nconst county = payload.county || \"Unknown County\";\nconst charges = payload.charges || \"Not specified\";\nconst bondAmount = payload.bondAmount ? `$${payload.bondAmount}` : \"TBD\";\n\nmsg.headers = {\n    \"Authorization\": \"Bearer SLACK_TOKEN_FROM_ENV\",\n    \"Content-Type\": \"application/json; charset=utf-8\"\n};\n\nmsg.payload = {\n    \"channel\": \"C09MP494D1T\",\n    \"blocks\": [\n        {\n            \"type\": \"header\",\n            \"text\": {\n                \"type\": \"plain_text\",\n                \"text\": \"🚨 New Intake Lead - \" + county,\n                \"emoji\": true\n            }\n        },\n        {\n            \"type\": \"divider\"\n        },\n        {\n            \"type\": \"section\",\n            \"fields\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Client Name:*\\n\" + name\n                },\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Phone:*\\n\" + phone\n                }\n            ]\n        },\n        {\n            \"type\": \"section\",\n            \"fields\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Charges:*\\n\" + charges\n                },\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Bond Amount:*\\n\" + bondAmount\n                }\n            ]\n        },\n        {\n            \"type\": \"divider\"\n        },\n        {\n            \"type\": \"context\",\n            \"elements\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"_Triggered by Wix Webhook Node-RED Flow_\"\n                }\n            ]\n        }\n    ]\n};\n\nreturn msg;",
  "outputs": 1,
  "timeout": 0,
  "noerr": 0,
  "initialize": "",
  "finalize": "",
  "libs": [],
  "x": 430,
  "y": 140,
  "wires": [
    [
      "node-slack-post"
    ]
  ]
}

{
  "id": "1c069a7f",
  "type": "ui-template",
  "z": "tab-shamrock",
  "group": "a73f65e3",
  "name": "Court Events Table",
  "order": 2,
  "width": 12,
  "height": 7,
  "format": "<div style=\"height:350px; overflow-y:scroll; padding:10px; background:#1e1e1e; border-radius:8px; border:1px solid #333;\">\n  <div v-if=\"!msg.payload || msg.payload.length === 0\" style=\"color:#888; text-align:center; margin-top:50px;\">\n    No upcoming court dates found. Click Refresh to check.\n  </div>\n  <table v-else style=\"width:100%; border-collapse:collapse; color:#fff; font-size:14px;\">\n    <thead>\n      <tr style=\"background:#333; text-align:left;\">\n        <th style=\"padding:10px; border-bottom:2px solid #555;\">Date & Time</th>\n        <th style=\"padding:10px; border-bottom:2px solid #555;\">Details</th>\n        <th style=\"padding:10px; border-bottom:2px solid #555;\">Location</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr v-for=\"event in msg.payload\" :key=\"event.title\" style=\"border-bottom:1px solid #333;\">\n        <td style=\"padding:10px; white-space:nowrap;\">\n          <strong style=\"color:#3b82f6;\">{{ new Date(event.startTime).toLocaleDateString('en-US', {weekday: 'short', month: 'short', day: 'numeric'}) }}</strong><br>\n          <span style=\"color:#aaa; font-size:12px;\">{{ new Date(event.startTime).toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit'}) }}</span>\n        </td>\n        <td style=\"padding:10px;\">\n          <strong style=\"font-size:15px;\">{{ event.title }}</strong>\n        </td>\n        <td style=\"padding:10px; color:#10b981;\">\n          <i class=\"fa fa-map-marker\"></i> {{ event.location || 'See Notice' }}\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
  "storeOutMessages": true,
  "fwdInMessages": true,
  "resendOnRefresh": true,
  "templateScope": "local",
  "className": "",
  "x": 850,
  "y": 2000,
  "wires": [
    []
  ]
}

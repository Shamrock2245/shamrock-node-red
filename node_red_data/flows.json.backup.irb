    {
        "id": "scout_filter_bounty",
        "type": "function",
        "z": "tab-advanced",
        "name": "Filter Bounty > $2,500",
        "func": "const payload = msg.payload || {};\\nconst arrests = Array.isArray(payload.arrests) ? payload.arrests : [payload];\\n\\nlet massiveBonds = arrests.filter(a => {\\n    const bondStr = String(a.BondAmount || a.bondAmount || '0').replace(/[^0-9.]/g, '');\\n    return parseFloat(bondStr) >= 2500;\\n});\\n\\nif (massiveBonds.length === 0) return null; // Drop if no large bonds\\n\\nconst blocks = massiveBonds.map(a => {\\n    return {\\n        \"type\": \"section\",\\n        \"text\": {\\n            \"type\": \"mrkdwn\",\\n            \"text\": `*Name:* ${a.DefendantName || a.name || 'Unknown'}\\n*County:* ${a.County || a.county || 'SWFL'}\\n*Bond:* $${a.BondAmount || a.bondAmount}\\n*Charges:* ${a.Charges || a.charges || 'Pending'}`\\n        }\\n    };\\n});\\n\\nmsg.payload = {\\n    \"channel\": \"C0ACWDRQWD9\",  // #new-cases\\n    \"text\": \"🚨 *High Value Arrest(s) Detected!* 🚨\",\\n    \"blocks\": [\\n        {\\n            \"type\": \"header\",\\n            \"text\": {\\n                \"type\": \"plain_text\",\\n                \"text\": \"🚨 The Scout: High Value Targets\",\\n                \"emoji\": true\\n            }\\n        },\\n        ...blocks\\n    ]\\n};\\n\\nmsg.headers = {\\n    \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\"),\\n    \"Content-Type\": \"application/json; charset=utf-8\"\\n};\\n\\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "x": 420,
        "y": 360,
        "wires": [
            [
                "node-slack-post"
            ]
        ]
    },

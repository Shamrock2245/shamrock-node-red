    {
        "id": "ui_form_court_doc",
        "type": "ui-form",
        "z": "phase5_tab",
        "name": "Generate Court Document",
        "group": "ui-group-court-filings",
        "order": 1,
        "width": 0,
        "height": 0,
        "payload": "",
        "submit": "Generate Document",
        "cancel": "Cancel",
        "topic": "generate_doc",
        "x": 200,
        "y": 1200,
        "wires": [
            [
                "fn_prepare_doc_req"
            ]
        ],
        "label": "Generate Court Document",
        "format": "[{\"type\": \"text\", \"id\": \"docType\", \"label\": \"Document Type\", \"width\": \"12\", \"required\": true}, {\"type\": \"text\", \"id\": \"defendantName\", \"label\": \"Defendant Name\", \"width\": \"12\", \"required\": true}, {\"type\": \"text\", \"id\": \"county\", \"label\": \"County\", \"width\": \"12\", \"required\": true}, {\"type\": \"text\", \"id\": \"caseNumber\", \"label\": \"Case Number\", \"width\": \"12\", \"required\": true}, {\"type\": \"text\", \"id\": \"bondAmount\", \"label\": \"Bond Amount\", \"width\": \"12\", \"required\": false}, {\"type\": \"text\", \"id\": \"estreatureDate\", \"label\": \"Estreature Date\", \"width\": \"12\", \"required\": false}]",
        "topicType": "msg",
        "className": ""
    },
    {
        "id": "fn_prepare_doc_req",
        "type": "function",
        "z": "phase5_tab",
        "name": "Format Doc Request",
        "func": "msg.payload = {\n    'action': 'generateCourtDocument',\n    'docType': msg.payload.docType.toLowerCase(),\n    'caseData': {\n        'defendantName': msg.payload.defendantName,\n        'county': msg.payload.county,\n        'courtName': 'CIRCUIT',\n        'caseNumber': msg.payload.caseNumber,\n        'bondAmount': msg.payload.bondAmount,\n        'estreatureDate': msg.payload.estreatureDate\n    }\n};\nmsg.headers = {\n    'Content-Type': 'application/json',\n    'x-api-key': global.get('gas_api_key') || ''\n};\nreturn msg;",
        "outputs": 1,
        "x": 450,
        "y": 1200,
        "wires": [
            [
                "http_req_doc"
            ]
        ]
    },
    {
        "id": "http_req_doc",
        "type": "http request",
        "z": "phase5_tab",
        "name": "Call GAS Webhook",
        "method": "POST",

        "format": "<div style='height:100%; overflow-y:scroll; padding:10px;' class='custom-inbox'>\n  <ul v-for=\"msg in msg.payload\" :key=\"msg.id\" style='list-style:none; padding:0;'>\n    <li style='margin-bottom:8px; display:flex; flex-direction:column;' :style='msg.isBot ? \"align-items:flex-start;\" : \"align-items:flex-end;\"'>\n      <div style='max-width:80%; padding:8px 12px; border-radius:12px;' :style='msg.isBot ? \"background:#333; color:#EEE;\" : \"background:#D4AF37; color:#121212;\"'>\n        <strong>{{msg.sender}}:</strong> {{msg.text}}\n      </div>\n    </li>\n  </ul>\n</div>",

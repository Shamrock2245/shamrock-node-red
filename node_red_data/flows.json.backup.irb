[
    {
        "id": "tab-shamrock",
        "type": "tab",
        "label": "Shamrock Automations",
        "disabled": false,
        "info": "This is the primary flow for receiving Wix webhooks and routing data to Twilio, Slack, or Google Apps Script."
    },
    {
        "id": "node-wix-webhook",
        "type": "http in",
        "z": "tab-shamrock",
        "name": "Wix Intake Webhook",
        "url": "/wix-intake",
        "method": "post",
        "upload": false,
        "swaggerDoc": "",
        "x": 130,
        "y": 140,
        "wires": [
            [
                "node-wix-response",
                "node-format-slack",
                "node-debug-payload"
            ]
        ]
    },
    {
        "id": "node-wix-response",
        "type": "http response",
        "z": "tab-shamrock",
        "name": "Send 200 OK",
        "statusCode": "200",
        "headers": {},
        "x": 370,
        "y": 80,
        "wires": []
    },
    {
        "id": "node-debug-payload",
        "type": "debug",
        "z": "tab-shamrock",
        "name": "Debug Wix Payload",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 390,
        "y": 200,
        "wires": []
    },
    {
        "id": "node-format-slack",
        "type": "function",
        "z": "tab-shamrock",
        "name": "Format Slack Block Kit message",
        "func": "const payload = msg.payload || {};\nconst name = payload.name || \"Unknown Client\";\nconst phone = payload.phone || \"No phone provided\";\nconst county = payload.county || \"Unknown County\";\nconst charges = payload.charges || \"Not specified\";\nconst bondAmount = payload.bondAmount ? `$${payload.bondAmount}` : \"TBD\";\n\nmsg.headers = {\n    \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\") ,\n    \"Content-Type\": \"application/json; charset=utf-8\"\n};\n\nmsg.payload = {\n    \"channel\": \"C09MP494D1T\",\n    \"blocks\": [\n        {\n            \"type\": \"header\",\n            \"text\": {\n                \"type\": \"plain_text\",\n                \"text\": \"🚨 New Intake Lead - \" + county,\n                \"emoji\": true\n            }\n        },\n        {\n            \"type\": \"divider\"\n        },\n        {\n            \"type\": \"section\",\n            \"fields\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Client Name:*\\n\" + name\n                },\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Phone:*\\n\" + phone\n                }\n            ]\n        },\n        {\n            \"type\": \"section\",\n            \"fields\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Charges:*\\n\" + charges\n                },\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"*Bond Amount:*\\n\" + bondAmount\n                }\n            ]\n        },\n        {\n            \"type\": \"divider\"\n        },\n        {\n            \"type\": \"context\",\n            \"elements\": [\n                {\n                    \"type\": \"mrkdwn\",\n                    \"text\": \"_Triggered by Wix Webhook Node-RED Flow_\"\n                }\n            ]\n        }\n    ]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 430,
        "y": 140,
        "wires": [
            [
                "node-slack-post"
            ]
        ]
    },
    {
        "id": "node-slack-post",
        "type": "http request",
        "z": "tab-shamrock",
        "name": "POST to Slack API",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "https://slack.com/api/chat.postMessage",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 710,
        "y": 140,
        "wires": [
            [
                "node-slack-response"
            ]
        ]
    },
    {
        "id": "node-slack-response",
        "type": "debug",
        "z": "tab-shamrock",
        "name": "Debug Slack Response",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "true",
        "targetType": "full",
        "statusVal": "",
        "statusType": "auto",
        "x": 940,
        "y": 140,
        "wires": []
    },
    {
        "id": "tab-advanced",
        "type": "tab",
        "label": "The Digital Workforce (Advanced)",
        "disabled": false,
        "info": "Shamrock Bail Bonds AI Workforce & Automations"
    },
    {
        "id": "a9943d9b",
        "type": "http in",
        "z": "tab-advanced",
        "name": "Wix Intake Started",
        "url": "/intake-start",
        "method": "post",
        "x": 130,
        "y": 180,
        "wires": [
            [
                "ef6f8f73"
            ]
        ]
    },
    {
        "id": "f3454d6e",
        "type": "http in",
        "z": "tab-advanced",
        "name": "Wix Intake Completed",
        "url": "/intake-complete",
        "method": "post",
        "x": 140,
        "y": 240,
        "wires": [
            [
                "bf3f6258"
            ]
        ]
    },
    {
        "id": "ef6f8f73",
        "type": "function",
        "z": "tab-advanced",
        "name": "Mark Pending",
        "func": "const phone = msg.payload.phone;\nif(phone) {\n    global.set('intake_' + phone, 'pending');\n    msg.phone = phone;\n    return msg;\n}",
        "outputs": 1,
        "x": 380,
        "y": 180,
        "wires": [
            []
        ]
    },
    {
        "id": "bf3f6258",
        "type": "function",
        "z": "tab-advanced",
        "name": "Mark Complete",
        "func": "const phone = msg.payload.phone;\nif(phone) {\n    global.set('intake_' + phone, 'complete');\n}\nreturn msg;",
        "outputs": 1,
        "x": 380,
        "y": 240,
        "wires": [
            [
                "prep_signnow_payload"
            ]
        ]
    },
    {
        "id": "3ba0bff6",
        "type": "http in",
        "z": "tab-advanced",
        "name": "SignNow Webhook",
        "url": "/signnow-event",
        "method": "post",
        "x": 130,
        "y": 440,
        "wires": [
            [
                "6b0f0efe",
                "2f242403"
            ]
        ]
    },
    {
        "id": "6b0f0efe",
        "type": "http response",
        "z": "tab-advanced",
        "name": "200 OK",
        "statusCode": "200",
        "x": 340,
        "y": 400,
        "wires": []
    },
    {
        "id": "2f242403",
        "type": "function",
        "z": "tab-advanced",
        "name": "Format \"Signed\" Alert",
        "func": "const event = msg.payload.meta || {};\nif(event.event === 'document.update' || true) { // Always trigger for demo\n    msg.payload = {\n        \"channel\": \"C09MSHM72D8\", // #bonds-live\n        \"text\": \"🎉 *Document Signed!* 🎉\\n> The indemnitor has completed the packet! Ready to post.\"\n    };\n    msg.headers = {\n        \"Authorization\": \"Bearer \" + (global.get(\"SLACK_TOKEN\") || \"\") ,\n        \"Content-Type\": \"application/json; charset=utf-8\"\n    };\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 380,
        "y": 480,
        "wires": [
            [
                "9673428d"
            ]
        ]
    },
    {
        "id": "9673428d",
        "type": "http request",
        "z": "tab-advanced",
        "name": "POST to #bonds-live",
        "method": "POST",
        "ret": "obj",
        "url": "https://slack.com/api/chat.postMessage",
        "x": 620,
        "y": 480,
        "wires": [
            []
        ]
    },

    {
        "id": "1b54db70",
        "type": "inject",
        "z": "tab-shamrock",
        "name": "Refresh Calendar (2hr)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "7200",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",

        "z": "tab-shamrock",
        "group": "3bf373650c1a4962",
        "name": "Red Flag Ledger",
        "order": 2,
        "width": 6,
        "height": 4,
        "format": "<template>\n  <div style=\"padding:8px\">\n    <h3 style=\"color:#ef4444;margin:0 0 8px\">ACTIVE RED FLAGS 🚩</h3>\n    <div v-if=\"msg?.payload\">\n      <div v-for=\"(item, i) in (Array.isArray(msg.payload) ? msg.payload : [])\" :key=\"i\" style=\"padding:6px 0;border-bottom:1px solid #333;color:#fca5a5\">\n        {{ typeof item === 'object' ? (item.title || item.name || JSON.stringify(item)) : item }}\n      </div>\n    </div>\n    <div v-else style=\"color:#888\">No red flags detected</div>\n  </div>\n</template>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",

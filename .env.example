# ═══════════════════════════════════════════════════════
# 🍀 Shamrock Node-RED — Environment Variables
# ═══════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git!
# ═══════════════════════════════════════════════════════

# ── Node-RED Core ──
NR_CREDENTIAL_SECRET=shamrock-bail-2026
# Generate: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
NR_ADMIN_HASH=

# ── Base URL ──
# The public-facing URL of this Node-RED instance (used for webhook endpoint generation).
# Set to your ngrok URL when tunneling, or your server's public IP/domain.
# Example: https://abc123.ngrok.io  or  http://YOUR_SERVER_IP:1880
NODE_RED_BASE_URL=http://localhost:1880

# ── Google Apps Script ──
GAS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GAS_API_KEY=

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#ops-alerts
SLACK_WEBHOOK_OPS=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_WEBHOOK_LEADS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Twilio ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+17272952245
# TWILIO_FROM_NUMBER is the SMS sender number (often same as TWILIO_PHONE_NUMBER)
TWILIO_FROM_NUMBER=+17272952245
# TWILIO_WA_NUMBER is the WhatsApp-enabled number (format: whatsapp:+1XXXXXXXXXX)
TWILIO_WA_NUMBER=whatsapp:+17272952245

# ── ElevenLabs ──
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=agent_2001kjth4na5ftqvdf1pp3gfb1cb
# ELEVENLABS_PHONE_ID is the Twilio phone number ID registered in ElevenLabs
ELEVENLABS_PHONE_ID=your-elevenlabs-phone-id

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── SignNow ──
SIGNNOW_API_KEY=your-signnow-api-key

# ── MongoDB Atlas ──
# IMPORTANT: Use the STANDARD (non-SRV) connection string for Docker compatibility.
# Docker's internal DNS cannot resolve mongodb+srv:// SRV records.
# Get this from Atlas → Connect → Drivers → toggle OFF "SRV Connection String"
# The replicaSet name for the Shamrock cluster is: atlas-bypoep-shard-0
MONGODB_URI=mongodb://admin:YOURPASSWORD@shamrock-shard-00-00.1mgkm.mongodb.net:27017,shamrock-shard-00-01.1mgkm.mongodb.net:27017,shamrock-shard-00-02.1mgkm.mongodb.net:27017/?ssl=true&replicaSet=atlas-bypoep-shard-0&authSource=admin&appName=Shamrock

# ── GitHub ──
# Personal Access Token with repo + workflow scopes (for Scraper Control tab)
GITHUB_PAT=github_pat_your_token_here

# ── Webhook Security ──
# Used for HMAC signature verification on inbound webhooks
# Generate with: openssl rand -hex 32
WEBHOOK_HMAC_SECRET=generate-a-random-32-char-hex-string

# ── Logging ──
LOG_LEVEL=info
